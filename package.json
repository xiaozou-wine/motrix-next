    "dompurify": "^3.4.8",
    "lettercoder": "^0.1.1",
    "lodash-es": "^4.18.1",
    "marked": "^17.0.4",
    "marked-alert": "^2.1.2",
    "naive-ui": "^2.44.1",
    "parse-torrent": "^11.0.21",
    "path-browserify": "^1.0.1",
    "picomatch": "^4.0.4",
