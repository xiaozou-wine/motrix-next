    "@types/node": "^24.13.1",
    "@types/path-browserify": "^1.0.3",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@unocss/preset-uno": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.8",
